<Window x:Class="CyberBotWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CyberBotWPF.ViewModels"
        xmlns:local="clr-namespace:CyberBotWPF.Views"
        Title="🛡️ CyberBot — Cybersecurity Awareness Assistant"
        Height="750" Width="1050"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E1A">

    <Window.DataContext>
        <vm:ChatViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0"
                Background="#0F1628"
                BorderBrush="#1E3A5F"
                BorderThickness="0,0,1,0">
            <StackPanel>

                <!-- Logo -->
                <Border Background="#0A0E1A"
                        Padding="15,20,15,15"
                        BorderBrush="#1E3A5F"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="#00D4FF"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center">
                            <Run Text="    /\    "/>
                            <LineBreak/>
                            <Run Text="   /  \   "/>
                            <LineBreak/>
                            <Run Text="  / SA \  "/>
                            <LineBreak/>
                            <Run Text=" /______\ "/>
                            <LineBreak/>
                            <Run Text=" | SAFE | "/>
                            <LineBreak/>
                            <Run Text=" \______/ "/>
                        </TextBlock>
                        <TextBlock Text="CYBER BOT"
                                   FontFamily="Consolas"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#00D4FF"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,2"/>
                        <TextBlock Text="Cybersecurity Awareness Assistant"
                                   FontSize="10"
                                   Foreground="#7A9BB5"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                        <Border Background="#1E3A5F"
                                CornerRadius="4"
                                Padding="8,4"
                                Margin="0,10,0,0">
                            <TextBlock Text="🇿🇦  South Africa · 2026"
                                       FontSize="10"
                                       Foreground="#00FF88"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Quick Topics -->
                <TextBlock Text="QUICK TOPICS"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="#7A9BB5"
                           Margin="15,15,15,8"
                           FontFamily="Consolas"/>

                <WrapPanel Margin="10,0">
                    <Button Content="🔑 Password"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="password"/>
                    <Button Content="🎣 Phishing"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="phishing"/>
                    <Button Content="🚨 Scams"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="scam"/>
                    <Button Content="🔒 Privacy"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="privacy"/>
                    <Button Content="🦠 Malware"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="malware"/>
                    <Button Content="🌐 Browsing"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="browsing"/>
                    <Button Content="🔐 2FA"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="2fa"/>
                    <Button Content="📶 Wifi"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="wifi"/>
                    <Button Content="🎮 Quiz"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="quiz"/>
                    <Button Content="📋 Tasks"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="open tasks"/>
                    <Button Content="📊 Log"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="show activity log"/>
                    <Button Content="❓ Help"
                            Style="{StaticResource ChipStyle}"
                            Click="Chip_Click" Tag="help"/>
                </WrapPanel>

                <Border Background="#1E3A5F" Height="1" Margin="15,15"/>

                <!-- Stats -->
                <TextBlock Text="DID YOU KNOW?"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="#7A9BB5"
                           Margin="15,0,15,10"
                           FontFamily="Consolas"/>

                <Border Background="#131D35"
                        CornerRadius="8"
                        Margin="10,0"
                        Padding="12">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#00FF88"
                                   FontSize="11"
                                   LineHeight="18">
                            <Run FontWeight="Bold" Text="R2.2 billion"/>
                            <Run Text=" lost to cybercrime in SA in 2023."/>
                        </TextBlock>
                        <Border Background="#1E3A5F" Height="1" Margin="0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#00D4FF"
                                   FontSize="11"
                                   LineHeight="18">
                            <Run FontWeight="Bold" Text="80%"/>
                            <Run Text=" of breaches involve weak passwords."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <Border Background="#0A0E1A"
                        CornerRadius="6"
                        Margin="10,15,10,10"
                        Padding="10,8">
                    <TextBlock x:Name="StatusLabel"
                               Text="{Binding StatusText}"
                               Foreground="#7A9BB5"
                               FontSize="11"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </Border>

        <!-- RIGHT CHAT PANEL -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0"
                    Background="#0F1628"
                    BorderBrush="#1E3A5F"
                    BorderThickness="0,0,0,1"
                    Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10"
                                 Fill="#00FF88"
                                 Margin="0,0,8,0"/>
                        <TextBlock Text="CyberBot Online"
                                   Foreground="#E8F4FD"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" · Dept of Cybersecurity SA"
                                   Foreground="#7A9BB5"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="ClockLabel"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#7A9BB5"
                               FontFamily="Consolas"
                               FontSize="12"/>
                </Grid>
            </Border>

            <!-- Chat Messages -->
            <ScrollViewer Grid.Row="1"
                          x:Name="ChatScrollViewer"
                          Background="#0A0E1A"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,15">
                <ItemsControl x:Name="MessagesList"
                              ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Border Background="#1E3A5F"
                                        CornerRadius="12"
                                        Padding="12,8"
                                        MaxWidth="500"
                                        HorizontalAlignment="Right"
                                        Margin="60,0,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding Sender}"
                                                    Value="user">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="#E8F4FD"
                                               FontSize="13"
                                               TextWrapping="Wrap"/>
                                </Border>
                                <Border CornerRadius="4,12,12,12"
                                        Padding="12,8"
                                        MaxWidth="550"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,60,0"
                                        Background="#0F1628"
                                        BorderBrush="#1E3A5F"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding Sender}"
                                                    Value="bot">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Topic}"
                                                   Foreground="#00D4FF"
                                                   FontSize="10"
                                                   FontFamily="Consolas"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="#E8F4FD"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input Area -->
            <Border Grid.Row="2"
                    Background="#0F1628"
                    BorderBrush="#1E3A5F"
                    BorderThickness="0,1,0,0"
                    Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="#131D35"
                            BorderBrush="#1E3A5F"
                            BorderThickness="1"
                            CornerRadius="10"
                            Margin="0,0,12,0">
                        <TextBox x:Name="InputBox"
                                 Text="{Binding InputText,
                                     UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 Foreground="#E8F4FD"
                                 CaretBrush="#00D4FF"
                                 BorderThickness="0"
                                 FontSize="13"
                                 Padding="14,10"
                                 VerticalContentAlignment="Center"
                                 KeyDown="InputBox_KeyDown"/>
                    </Border>
                    <Button Grid.Column="1"
                            Content="Send"
                            Style="{StaticResource SendButtonStyle}"
                            Width="80"
                            Height="42"
                            Click="SendButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>