<Window x:Class="CyberBotWPF.Views.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎮 Cybersecurity Quiz"
        Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E1A"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🎮 CYBERSECURITY QUIZ"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#00D4FF"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Test your cybersecurity knowledge!"
                       FontSize="12" Foreground="#7A9BB5"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ProgressBar"
                         Height="8"
                         Background="#1E3A5F"
                         Foreground="#00D4FF"
                         Minimum="0" Maximum="10"/>
            <TextBlock x:Name="ProgressLabel"
                       Grid.Column="1"
                       Foreground="#7A9BB5"
                       FontFamily="Consolas"
                       FontSize="12"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="2"
                Background="#0F1628"
                BorderBrush="#1E3A5F"
                BorderThickness="1"
                CornerRadius="12"
                Padding="25">
            <StackPanel>
                <TextBlock x:Name="QuestionText"
                           FontSize="15"
                           Foreground="#E8F4FD"
                           TextWrapping="Wrap"
                           LineHeight="24"
                           Margin="0,0,0,20"
                           FontWeight="SemiBold"/>
                <StackPanel x:Name="OptionsPanel"/>
                <Border x:Name="FeedbackBorder"
                        CornerRadius="8"
                        Padding="15,10"
                        Margin="0,15,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="FeedbackText"
                               FontSize="13"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Background="#131D35"
                CornerRadius="8"
                Padding="15,8"
                Margin="0,15,0,15">
            <Grid>
                <TextBlock x:Name="ScoreLabel"
                           Foreground="#00FF88"
                           FontFamily="Consolas"
                           FontSize="13"
                           FontWeight="Bold"/>
                <TextBlock x:Name="ResultLabel"
                           HorizontalAlignment="Right"
                           Foreground="#FFD700"
                           FontSize="13"
                           FontWeight="Bold"/>
            </Grid>
        </Border>

        <Button x:Name="NextButton"
                Grid.Row="4"
                Content="Next Question ➤"
                Height="45"
                FontSize="14"
                FontWeight="Bold"
                Foreground="#0A0E1A"
                Cursor="Hand"
                Click="NextButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#00D4FF" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>